{
    "swagger": "2.0",
    "info": {
        "description": "API for generating random NPC descriptors.",
        "title": "NPC Descriptor API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/descriptors": {
            "get": {
                "description": "returns random NPC descriptors as a JSON list. Optional query param 'n' (1-10) sets count (default 3).",
                "produces": [
                    "application/json"
                ],
                "summary": "Get NPC descriptors",
                "parameters": [
                    {
                        "maximum": 10,
                        "minimum": 1,
                        "type": "integer",
                        "default": 3,
                        "description": "Number of descriptors",
                        "name": "n",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.DescriptorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.DescriptorResponse": {
            "type": "object",
            "properties": {
                "descriptors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    }
}